# =====================================================
# CampaignHub SMS Marketing Platform
# Environment Variables Configuration
# =====================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Option 1: Connection URL (recommended for cloud databases like Neon)
DATABASE_URL=postgresql://username:password@hostname:5432/database_name?sslmode=require

# Option 2: Individual connection parameters (for local development)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=campaign_hub

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Base URL (for webhook callbacks)
# In production, set this to your deployed API URL
BASE_URL=http://localhost:5000

# =====================================================
# IMPORTANT: Twilio credentials are stored in the database
# per user, not in environment variables. Users configure
# their Twilio settings through the /api/settings/twilio
# endpoint after logging in.
# =====================================================
